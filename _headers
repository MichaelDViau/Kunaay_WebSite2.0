# Netlify / Cloudflare Pages headers — performance & security
# (Inert on hosts that don't read this file, e.g. Apache uses .htaccess.)

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# Long-lived, fingerprint-free media, icons & fonts
/assets/img/*
  Cache-Control: public, max-age=31536000, immutable

/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Code changes occasionally — cache a day, then revalidate
/assets/js/*
  Cache-Control: public, max-age=86400, must-revalidate

/assets/css/*
  Cache-Control: public, max-age=86400, must-revalidate

# HTML — short cache so content updates propagate quickly
/*.html
  Cache-Control: public, max-age=600, must-revalidate
