# Copy this file to ".env" (the Prisma CLI and Next.js both read .env).
#   cp .env.example .env
# .env is gitignored, so your secrets stay out of git.

# Database for Prisma/NextAuth.
# Local SQLite development (default), then run: npx prisma migrate dev
DATABASE_URL="file:./dev.db"

# Required by NextAuth. For local dev, any strong random value works.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Admin login. These are used by the seed script (npx prisma db seed) to create
# the admin user, and as a fallback login if the database is unavailable.
ADMIN_EMAIL="admin@kunaay.com"
ADMIN_PASSWORD="Passwordkunaay2026"

# Supabase note:
# A publishable/anon key is not enough for Prisma. To use Supabase as the database,
# copy the Supabase PostgreSQL connection string into DATABASE_URL above.
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_-FR-IHbcjOFvOUOj47wVTA_5qzxca3N"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# AI assistant (OpenRouter). Get a free key at https://openrouter.ai/keys
# Without a key the assistant still answers with built-in canned responses.
OPENROUTER_API_KEY="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"
OPENROUTER_MODEL="google/gemma-3-27b-it:free"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
