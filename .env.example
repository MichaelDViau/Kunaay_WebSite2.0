# Local development fallback database for Prisma/NextAuth.
# Use this for SQLite development, then run: npx prisma migrate dev
DATABASE_URL="file:./dev.db"

# Required by NextAuth in production. For local dev, any strong random value works.
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Supabase note:
# A publishable/anon key is not enough for Prisma. To use Supabase as the database,
# copy the Supabase PostgreSQL connection string into DATABASE_URL above.
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_-FR-IHbcjOFvOUOj47wVTA_5qzxca3N"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
